{
  "name": "structureddiary",
  "version": "1.0.0",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "build": "vite build",
    "dev_build": "vite build --watch",
    "serve": "vite",
    "dev": "vite --mode development build",
    "lint": "eslint src",
    "stylelint": "stylelint src/**/*.vue src/**/*.scss src/**/*.css",
    "watch": "vite --mode development build --watch",
    "cypress": "cypress open",
    "cypress:cmp": "cypress run --component",
    "cypress:e2e": "cypress run --e2e",
    "cypress:gui": "cypress open --e2e",
    "cypress:visual-regression": "cypress run --spec cypress/e2e/visual-regression.cy.ts",
    "cypress:update-snapshots": "cypress run --env visualRegressionType=base --spec cypress/e2e/visual-regression.cy.ts --config screenshotsFolder=cypress/snapshots/base"

  },
  "browserslist": [
    "extends @nextcloud/browserslist-config"
  ],
  "dependencies": {
    "@nextcloud/vue": "^9.3.1",
    "vue": "^3.5.25"
  },
  "devDependencies": {
    "@nextcloud/browserslist-config": "^3.1.2",
    "@nextcloud/eslint-config": "^8.4.2",
    "@nextcloud/stylelint-config": "^3.1.1",
    "@nextcloud/vite-config": "^2.5.2",
    "@vue/tsconfig": "^0.8.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.7"
  },
  "engines": {
    "node": "^24.0.0",
    "npm": "^11.3.0"
  }
}
