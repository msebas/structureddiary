{
  "name": "structureddiary",
  "version": "1.0.0",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "build": "vite build",
    "dev_build": "vite build --watch",
    "serve": "vite",
    "dev": "vite --mode development dev",
    "lint": "eslint src",
    "stylelint": "stylelint src/**/*.vue src/**/*.scss src/**/*.css",
    "watch": "vite --mode development build --watch",
    "cypress": "cypress open",
    "cypress:cmp": "cypress run --component",
    "cypress:e2e": "cypress run --e2e",
    "cypress:gui": "cypress open --e2e",
    "cypress:visual-regression": "cypress run --spec cypress/e2e/visual-regression.cy.ts",
    "cypress:update-snapshots": "cypress run --env visualRegressionType=base --spec cypress/e2e/visual-regression.cy.ts --config screenshotsFolder=cypress/snapshots/base"
  },
  "browserslist": [
    "extends @nextcloud/browserslist-config"
  ],
  "dependencies": {
    "@mdi/js": "~7.4.47",
    "@nextcloud/vue": "^9.6.0",
    "@nextcloud/router": "^3.1.0",
    "@primeuix/themes": "^2.0.3",
    "easymde": "^2.20.0",
    "pinia": "^3.0.4",
    "primevue": "^4.5.5",
    "vite": "^7.3.2",
    "vue": "^3.5.32",
    "vue3-easymde": "^1.0.1",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@nextcloud/browserslist-config": "^3.1.2",
    "@nextcloud/e2e-test-server": "^0.4.0",
    "@nextcloud/eslint-config": "^8.4.2",
    "@nextcloud/stylelint-config": "^3.2.1",
    "@nextcloud/vite-config": "^2.5.2",
    "@vue/tsconfig": "^0.9.1",
    "cypress": "~15.14.0",
    "cypress-split": "^1.24.31",
    "cypress-visual-regression": "^5.3.0",
    "cypress-vite": "^1.8.0",
    "typescript": "^5.9.3",
    "vite-plugin-node-polyfills": "^0.26.0"
  },
  "engines": {
    "node": "^24.0.0",
    "npm": "^11.3.0"
  }
}
